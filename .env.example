# Public site URL used for metadata, OG tags, and canonical URLs
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Resend API key used by the contact form API
RESEND_API_KEY=re_your_api_key_here

# Optional: Cloudflare Turnstile secret key for spam protection
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
